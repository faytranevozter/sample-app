PORT=5050
GO_ENV=production

# logger
LOG_TO_STDOUT=true
LOG_MAX_SIZE=50

# db connection
DB_URL=mysql://user:password@localhost:3306/db-name

# redis cache
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=60s
REDIS_KEY_PREFIX="app:"

# jwt
JWT_MEMBER_SECRET_KEY=
JWT_MEMBER_TTL=60 # in minutes

# S3
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=bucket-name
S3_PUBLIC_URL=
